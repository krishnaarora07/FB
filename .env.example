# YouTube Data API key for discovery.
YOUTUBE_API_KEY=

# Gemini API key. google-genai can also read GOOGLE_API_KEY.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# ElevenLabs text-to-speech.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Pexels video search.
PEXELS_API_KEY=

# Shotstack render/upload. Use stage while testing on a free/sandbox account.
SHOTSTACK_API_KEY=
SHOTSTACK_VERSION=stage

# Creatomate video generation.
CREATOMATE_API_KEY=

# YouTube upload OAuth. Download this JSON from Google Cloud OAuth credentials.
YOUTUBE_CLIENT_SECRETS_FILE=client_secret.json
YOUTUBE_TOKEN_FILE=token.json
YOUTUBE_UPLOAD_PRIVACY_STATUS=private
YOUTUBE_UPLOAD_CATEGORY_ID=17

# Discovery tuning.
FIFA_CHANNEL_HANDLE=@FIFA
YOUTUBE_TREND_REGIONS=US,GB,IN
MAX_TRENDING_PER_REGION=25
MAX_FIFA_UPLOADS=25
FOOTBALL_KEYWORDS=football,soccer,fifa,world cup,worldcup,world cup 2026,2026 world cup,club world cup,qualifier,qualifiers,fixture,squad,draw,goal,goals,striker,keeper,penalty

# Output tuning.
OUTPUT_DIR=runs
SCRIPT_SECONDS=60
MAX_SIGNALS_FOR_GEMINI=35

